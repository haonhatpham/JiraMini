NODE_ENV=development
PORT=3001
APP_PREFIX=/v1/api

DATABASE_URL=your-database-connection-string-here

JWT_SECRET=local-development-jwt-secret-please-change-123456
JWT_ISSUER=jiramini
JWT_EXPIRES_IN=1h

# Khi deploy frontend trên Vercel/Netlify, đặt URL frontend ở đây.
# Ví dụ: https://my-jiramini-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_CREDENTIALS=true
